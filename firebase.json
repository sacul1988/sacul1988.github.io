{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "package.json",
      "package-lock.json",
      "check.js",
      "**/*.test.js",
      "eslint.config.mjs",
      "firestore.rules",
      "tests/**",
      "assets/screenshots/**"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git"]
    }
  ]
}
