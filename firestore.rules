rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userData
    // Document ID: {userId} (Matches the authenticated user's UID)
    // Fields:
    //   - lastUpdate: string (required) - ISO 8601 timestamp of last sync
    //   - classes: list (required) - Array of classes, students, grades
    //   - termine: list (required) - Array of calendar events
    //   - deletedTermineIds: list (required) - Array of deleted event IDs
    //   - planung: map | string (required) - Unterrichtsplanung pro Klassen-Index;
    //       neu als JSON-String (atomarer Replace via merge:true), map = Altformat
    //   - planung_global_calendar_range: map (required) - Global calendar configuration
    //   - zeugnistexteArchiv: list (required) - Archived report texts
    //   - contacts: list (required) - Address book contacts
    //   - extraDataLastUpdate: string (required) - Timestamp for local extra data synchronization
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate required fields exist
    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    // Enforce size limits and basic data type validation
    //
    // Hinweis: Es wird BEWUSST nicht via hasOnlyAllowedFields auf "nur diese
    // Felder" eingeschränkt. Die App schreibt mit setDoc(..., { merge: true }),
    // und das Schema ist über die Zeit gewachsen. Bei einem Update prüfen die
    // Regeln das vollständige Dokument NACH dem Merge – enthält es noch ein
    // Altfeld aus einer früheren Version, würde hasOnly jeden Schreibvorgang
    // ablehnen (permission-denied). Pflichtfelder, Typen und Größen werden
    // weiterhin streng validiert, der Zugriff bleibt strikt auf den Eigentümer
    // beschränkt.
    function isValidUserData(data) {
      return hasRequiredFields(data, [
        'lastUpdate', 'classes', 'termine', 'deletedTermineIds',
        'planung', 'planung_global_calendar_range',
        'zeugnistexteArchiv', 'contacts', 'extraDataLastUpdate'
      ]) &&
      data.lastUpdate is string && data.lastUpdate.size() <= 40 &&
      data.extraDataLastUpdate is string && data.extraDataLastUpdate.size() <= 40 &&
      data.classes is list && data.classes.size() <= 100 &&
      data.termine is list && data.termine.size() <= 1000 &&
      data.deletedTermineIds is list && data.deletedTermineIds.size() <= 1000 &&
      // planung wird neu als JSON-STRING geschrieben (merge:true ersetzt es dann
      // atomar, damit gelöschte Einträge propagieren). Map weiterhin erlauben für
      // noch nicht aktualisierte Geräte (Abwärtskompatibilität während der Umstellung).
      (data.planung is map || data.planung is string) &&
      data.planung_global_calendar_range is map &&
      data.zeugnistexteArchiv is list && data.zeugnistexteArchiv.size() <= 2000 &&
      data.contacts is list && data.contacts.size() <= 500;
    }

    // Rules for userData documents
    match /userData/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Deny queries across multiple users' data
      allow create: if isOwner(userId) && isValidUserData(request.resource.data);
      allow update: if isOwner(userId) && isValidUserData(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Halbjahr-Archiv: genau ein vollständiger Snapshot pro Nutzer (uid = Doc-ID),
    // getrennt vom Live-Dokument. Der Snapshot liegt als JSON-String in `dataJson`.
    match /halbjahrArchive/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update: if isOwner(userId)
        && request.resource.data.dataJson is string
        && request.resource.data.dataJson.size() <= 1000000
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200;
      allow delete: if isOwner(userId);
    }
  }
}
