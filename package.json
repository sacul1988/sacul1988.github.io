{
  "name": "schulverwaltung",
  "private": true,
  "version": "1.0.0",
  "description": "Schulverwaltung – Dev-Tooling (Lint & Pre-Deploy-Checks)",
  "scripts": {
    "lint": "eslint grades.js script.js check.js *.test.js functions/*.js tests/**/*.js",
    "test": "node --test",
    "test:ui": "node --test tests/ui/zeugnistexte.playwright.js",
    "verify": "npm run check && npm run lint && npm test",
    "check": "node check.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0"
  }
}
